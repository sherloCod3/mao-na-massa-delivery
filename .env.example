# ─── Mão na Massa — Configuração ─────────────────────────────────
# Copie este arquivo para .env e ajuste os valores.

# ─── Banco de Dados ─────────────────────────────────────────────
# Padrão: SQLite local. Para Railway Volume, use:
#   sqlite+aiosqlite:////data/mao-na-massa.db
# Para PostgreSQL, use:
#   postgresql+asyncpg://user:password@host:5432/mao-na-massa
DATABASE_URL=sqlite+aiosqlite:///./mao-na-massa.db

# ─── Ambiente ──────────────────────────────────────────────────
# "development" | "production"
# Em production, docs/redoc/openapi são desabilitados
ENVIRONMENT=development

# ─── Hosts permitidos (TrustedHostMiddleware) ────────────────────
# Hosts que o servidor aceita no header Host.
# Em produção, liste os domínios exatos (ex: api.maonamassa.com.br).
# Use "*" para aceitar qualquer host (apenas em dev).
ALLOWED_HOSTS=*

# ─── CORS ───────────────────────────────────────────────────────
# Origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173

# ─── CSP (Content Security Policy) ──────────────────────────────
# Custom CSP header. Se vazio, usa o padrão seguro.
# Configure para produção se precisar de regras específicas.
CSP_POLICY=

# ─── Autenticação Admin ─────────────────────────────────────────
# Token fixo para acesso ao painel admin.
# Gere com: openssl rand -hex 32
# Se vazio, a autenticação fica desabilitada (útil em dev)
ADMIN_TOKEN=

# ─── Telegram (notificações) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Estoque (alertas) ──────────────────────────────────────────
# Quantidade mínima para disparar alerta de estoque baixo
# (aplica-se a ingredientes que não têm estoque_minimo definido)
ESTOQUE_MINIMO=100.0
ESTOQUE_MINIMO_PRECO=30.0

# ─── WhatsApp (Evolution API — self-hosted) ─────────────────────
# URL da API Evolution (ex: http://localhost:8080)
EVOLUTION_API_URL=
# Chave de autenticação da Evolution API
EVOLUTION_API_KEY=

# ─── App (links externos em notificações) ───────────────────────
APP_URL=http://localhost:5173
